# ══════════════════════════════════════════════════════════════
#  Aegis PM – Environment Variables
#  Copy this file to .env and fill in your real values.
# ══════════════════════════════════════════════════════════════

# ── PostgreSQL ─────────────────────────────────────────────────
POSTGRES_USER=aegis
POSTGRES_PASSWORD=aegispassword
POSTGRES_DB=aegispm
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Full async DSN (auto-built by app, but can override)
# DATABASE_URL=postgresql+asyncpg://aegis:aegispassword@postgres:5432/aegispm

# ── OpenAI (required by AutoGen) ───────────────────────────────
OPENAI_API_KEY=sk-...

# ── Jira ───────────────────────────────────────────────────────
# Your Atlassian account email
JIRA_EMAIL=you@yourcompany.com

# API token from: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your_jira_api_token_here

# Base URL of your Jira instance (no trailing slash)
# Cloud:  https://yourcompany.atlassian.net
# Server: https://jira.yourcompany.com
JIRA_BASE_URL=https://yourcompany.atlassian.net

# The Jira project key to monitor (e.g. ENG, PROJ, DEV)
JIRA_PROJECT_KEY=ENG

# How many days without update = stale (default 2)
STALE_DAYS=2

# How often to poll Jira in seconds (default 300 = 5 min)
POLL_INTERVAL_SECONDS=300

# ── Slack ──────────────────────────────────────────────────────
# Incoming Webhook URL from: https://api.slack.com/apps → Your App → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...

# Optional: default channel override (the webhook has its own channel,
# but you can post to specific users like @john.doe)
SLACK_DEFAULT_CHANNEL=#project-alerts

# ── FastAPI ────────────────────────────────────────────────────
API_BASE_URL=http://api:8000

# ── Logging ────────────────────────────────────────────────────
LOG_LEVEL=INFO


# ── Spec Interpreter ────────────────────────────────────────────────────────
# OpenAI model used by AutoGen agents (gpt-4o recommended)
OPENAI_MODEL=gpt-4o
# Default Jira issue type when creating tasks from a PRD
SPEC_DEFAULT_ISSUE_TYPE=Story
# Default priority for created tasks
SPEC_DEFAULT_PRIORITY=Medium
# Optional: Epic key to link all created tasks to (leave blank to skip)
SPEC_DEFAULT_EPIC_LINK=

# ── Agent mode ─────────────────────────────────────────────────
# "agents"    → Monitor + Communicator run independently (default)
# "groupchat" → All agents share one AutoGen GroupChat conversation per cycle
AEGIS_MODE=agents

# ── Port overrides (optional) ───────────────────────────────────────────────
# Change these if the default ports conflict with other services on your machine
POSTGRES_HOST_PORT=5432
API_HOST_PORT=8000
FRONTEND_HOST_PORT=3000

# ── Production settings ─────────────────────────────────────────────────────
# Number of gunicorn workers (production Dockerfile stage only)
WEB_CONCURRENCY=2

# CORS origins to allow (comma-separated, default * for dev)
CORS_ORIGINS=*
# Production example: CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# ── Security ────────────────────────────────────────────────────────────────
# Generate with: python api/security.py
AGENT_API_KEY=generate_me_with_python_api_security_py
ADMIN_API_KEY=generate_me_with_python_api_security_py_different_value
# Set to "true" to reject requests with missing/wrong API keys
AEGIS_ENFORCE_AUTH=false
# Per-IP rate limiting (requests per window)
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

# ── Dashboard auth (nginx Basic Auth) ───────────────────────────────────────
# Generate htpasswd: htpasswd -nb admin yourpassword
# Then set DASHBOARD_HTPASSWD_HASH to the output line
DASHBOARD_HTPASSWD_HASH=admin:$apr1$...

# ── Notification cooldown ────────────────────────────────────────────────────
# Hours that must pass before re-notifying about the same stale task
# Default 24 = once per day per task. Set to 0 to disable cooldown.
NOTIFY_COOLDOWN_HOURS=24

# ── Agent health monitoring ──────────────────────────────────────────────────
# Fire Slack alert after this many consecutive agent failures
HEALTH_ALERT_AFTER_FAILURES=2
# Mark agent as stale if it hasn't succeeded in this many seconds (12 min default)
HEALTH_STALE_SECS=720
